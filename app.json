{
  "expo": {
    "name": "Meals-app",
    "slug": "Meals-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#24180f",
    "icon": "./src/assets/icon.png",
    "scheme": "mealsapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ismoilabdujalilov.mealsapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ismoilabdujalilov.Mealsapp"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./src/assets/splash.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7b60988a-8aaa-4de3-ac10-1fb126cbe8f6"
      }
    }
  }
}
